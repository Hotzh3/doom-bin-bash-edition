# Browser runtime contract.
# Keep local overrides in .env.local or .env.production.local.

# Build metadata surfaced in the runtime footer and dist manifest.
VITE_APP_VERSION=0.1.0
VITE_APP_BUILD_SHA=local
VITE_APP_BUILD_DATE=2026-05-12T00:00:00.000Z
VITE_APP_RUNTIME_CHANNEL=development
VITE_APP_TELEMETRY=local

# Vite base path.
# Use "/" for local dev and release artifacts.
# Use "/<repo-name>/" for GitHub Pages.
BASE_PATH=/
