{
  "name": "doom-bin-bash-edition",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-runtime.mjs",
    "build:preview": "RAYCAST_RUNTIME_CHANNEL=preview BASE_PATH=/${npm_package_name}/ node scripts/build-runtime.mjs",
    "build:release": "RAYCAST_RUNTIME_CHANNEL=release node scripts/build-runtime.mjs",
    "pages:build": "RAYCAST_RUNTIME_CHANNEL=preview BASE_PATH=/${npm_package_name}/ node scripts/build-runtime.mjs",
    "pages:preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "preview:dist": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:up:d": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f game",
    "docker:dev": "vite --host 0.0.0.0 --port 5173",
    "docker:preview": "vite preview --host 0.0.0.0 --port 5173",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "runtime:info": "node scripts/runtime-info.mjs",
    "capture:media": "node scripts/capture-portfolio.mjs"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "playwright": "^1.55.1",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
